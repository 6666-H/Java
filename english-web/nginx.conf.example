# English 学习系统 Nginx 配置示例
# 用法：复制到服务器 /etc/nginx/sites-available/ 或 conf.d/，修改后执行 nginx -t && nginx -s reload

server {
    listen 80;
    server_name 116.62.133.154;    # 暂时用 IP，有域名后可改成域名

    # 前端静态文件（Vue 打包后的 dist 目录）
    root /var/www/english-web/dist;
    index index.html;

    # SPA 路由支持：所有非文件请求返回 index.html
    location / {
        try_files $uri $uri/ /index.html;
    }

    # API 反向代理到后端
    location /api/ {
        proxy_pass http://127.0.0.1:8089/api/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # 静态资源缓存
    location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2)$ {
        expires 1y;
        add_header Cache-Control "public, immutable";
    }
}
